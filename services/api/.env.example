# Copy to .env and fill in real values. Never commit the real .env.

NODE_ENV=development
PORT=4000

# postgres+postgis container from docker-compose.yml (host: localhost when running api outside Docker)
DATABASE_URL=postgresql://slm:slm_dev_password@localhost:5432/smart_lorry_marketplace?schema=public

# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=replace-with-32+-char-random-string
JWT_REFRESH_SECRET=replace-with-a-different-32+-char-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# Required from Phase 6 onward (KYC document encryption). Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

CORS_ORIGIN=http://localhost:5173

# Required from Phase 2 onward (distance/geocoding/directions)
GOOGLE_MAPS_API_KEY=

REDIS_URL=redis://localhost:6379

# Required from Phase 2 onward (payments). Leave blank to use the dev mock adapter.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
